# ====== Ponto Fácil · Supabase ======
# Copie este arquivo para ".env" e preencha com os dados do seu projeto.
# Painel Supabase → Settings → API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# Sem essas variáveis o app roda em modo LOCAL (mock + tempo real entre abas).
# Com elas preenchidas e o SQL aplicado, o app usa Auth + Realtime + banco.
